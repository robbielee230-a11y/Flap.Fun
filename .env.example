# Copy to .env for local dev, or set these in your host's dashboard (Railway/Render).

# REQUIRED in production. A long random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If this changes, all in-flight run tickets become invalid (fine on deploy).
SESSION_SECRET=

# Postgres connection string. On Railway/Render, the managed PG addon sets this
# for you automatically. Leave empty locally to use the in-memory fallback.
DATABASE_URL=

# Lock CORS + browser access to your front-end origin in production, e.g.
#   https://flappgame.xyz
# Leave as * only for local testing.
ALLOWED_ORIGIN=*

# Set to 1 to require a Phantom wallet signature at /run/start (ties scores to a
# real wallet instead of a free-text handle). Needs the client to sign a login
# message. Leave unset/0 for the handle-only test version.
REQUIRE_WALLET=0

# Port (host usually sets this automatically).
PORT=8787
