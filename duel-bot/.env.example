# ---- Copy to .env and fill in. .env is gitignored. ----

# duel.com (the crypto casino/sportsbook). Login is a MODAL on the homepage.
SITE_URL=https://duel.com
LOGIN_URL=https://duel.com
# The sportsbook route — confirm the exact path in your browser and set it.
SPORTSBOOK_URL=https://duel.com/sports

# ---- What to bet on (inside the BetBy sportsbook widget) ----
# Free-text typed into BetBy's search box (e.g. a tournament or player).
EVENT_SEARCH=ITF
# Exact selection text to click/back (e.g. a player's name). Leave blank to just
# click the first odds button that matches SEL_SB_ODDS (testing only).
SELECTION_TEXT=

# Credentials (optional — you can also just log in by hand in the window once).
DUEL_USERNAME=
DUEL_PASSWORD=

# ---- Safety guardrails (enforced before every bet) ----
DRY_RUN=true          # simulate: arm the bet slip but never click place-bet. Start here.
STAKE=1               # stake per bet, in the site's units
MAX_STAKE=5           # never place a single bet larger than this
MAX_BETS=3            # stop after this many bets in one run
STOP_LOSS=25          # (reserved) stop if net loss reaches this
TAKE_PROFIT=50        # (reserved) stop if net profit reaches this
BET_INTERVAL_MS=4000  # pause between bets

# ---- Browser ----
HEADLESS=false                     # false = watch the window (needed for 1st login / 2FA)
STORAGE_STATE=./.auth/state.json   # cached logged-in session

# ---- Selectors ----
# Defaults are best-effort. Capture the real ones with `npm run inspect` on a
# logged-in session, then set the SEL_* vars below. The SEL_SB_* ones live
# INSIDE the BetBy iframe.
# SEL_OPEN_LOGIN=button:has-text("Sign in")
# SEL_USERNAME=input[type="email"]
# SEL_PASSWORD=input[type="password"]
# SEL_LOGIN_BTN=button[type="submit"]
# SEL_LOGGED_IN=[href*="wallet"]
# SEL_BETBY_IFRAME=iframe[src*="betby"]
# SEL_SB_SEARCH=input[type="search"]
# SEL_SB_ODDS=[class*="outcome"]
# SEL_SB_STAKE=input[inputmode="decimal"]
# SEL_SB_PLACE=button:has-text("Place bet")
# SEL_SB_CONFIRM=button:has-text("Confirm")
