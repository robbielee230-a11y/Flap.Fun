# ---- Copy to .env and fill in. .env is gitignored. ----

# The betting site
SITE_URL=https://example-duel-site.com
LOGIN_URL=https://example-duel-site.com/login
DUEL_URL=https://example-duel-site.com/duel

# Credentials (only if you use the built-in login flow; otherwise use a saved session)
DUEL_USERNAME=
DUEL_PASSWORD=

# ---- Safety guardrails (all enforced before every bet) ----
# true = simulate only, never actually click the final confirm button. Start here.
DRY_RUN=true
# amount staked per bet, in the site's units
STAKE=1
# never place a single bet larger than this
MAX_STAKE=5
# stop after this many total bets in one run
MAX_BETS=10
# stop the whole run if cumulative net loss reaches this (positive number)
STOP_LOSS=25
# stop the whole run if cumulative net profit reaches this
TAKE_PROFIT=50
# milliseconds to wait between bets (be polite / avoid rate limits)
BET_INTERVAL_MS=4000

# ---- Browser ----
# false = show the browser window (recommended while testing). true = headless.
HEADLESS=false
# where the logged-in session is cached so you don't log in every run
STORAGE_STATE=./.auth/state.json
